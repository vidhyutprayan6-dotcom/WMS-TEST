# Supabase → Connect → ORMs → Prisma (copy both strings)

# LOCAL WINDOWS: use Direct connection as DATABASE_URL (pooler port 6543 crashes Prisma on Windows)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# RAILWAY PRODUCTION: use Session pooler (port 6543) as DATABASE_URL instead
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@...pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — for migrations
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

PORT=3006
NODE_ENV=development
# Set true to force in-memory demo mode (no Supabase needed for local testing)
USE_DEMO_MODE=false
FRONTEND_URL="https://your-app.vercel.app"
API_URL="http://localhost:3006"
