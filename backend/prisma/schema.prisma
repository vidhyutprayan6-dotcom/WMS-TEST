// WMS 3PL — schema aligned to client test requirements
// A. Storage Billing  B. Stock Transfer + Traceability  + Audit Trail + Multi-tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Pallet-based or volume-based (M³) monthly storage billing
enum BillingType {
  PALLET
  VOLUME
}

/// INBOUND/OUTBOUND feed billing fees; TRANSFER records bin-to-bin moves
enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
}

/// B2B tenant — strict data isolation via clientId on all stock tables
model Client {
  id          String      @id @default(uuid())
  name        String
  billingType BillingType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users          User[]
  products       Product[]
  inventory      Inventory[]
  stockMovements StockMovement[]
  billingRate    BillingRate?
  invoices       Invoice[]

  @@map("clients")
}

/// Operator identity for audit trail (who performed the action)
model User {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client         Client          @relation(fields: [clientId], references: [id])
  stockMovements StockMovement[]

  @@index([clientId])
  @@map("users")
}

/// Physical site containing bin/rack locations
model Warehouse {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bins Bin[]

  @@map("warehouses")
}

/// Bin/Rack — capacity enforced on transfer (over-capacity validation)
model Bin {
  id              String   @id @default(uuid())
  warehouseId     String
  code            String
  capacityPallets Int
  capacityM3      Float
  currentPallets  Int      @default(0)
  currentM3       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  warehouse          Warehouse       @relation(fields: [warehouseId], references: [id])
  inventory          Inventory[]
  stockMovementsFrom StockMovement[] @relation("FromBin")
  stockMovementsTo   StockMovement[] @relation("ToBin")

  @@unique([warehouseId, code])
  @@map("bins")
}

/// SKU catalog — scoped per tenant
model Product {
  id        String   @id @default(uuid())
  clientId  String
  sku       String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client         Client          @relation(fields: [clientId], references: [id])
  inventory      Inventory[]
  stockMovements StockMovement[]

  @@unique([clientId, sku])
  @@index([clientId])
  @@map("products")
}

/// On-hand stock with batch/lot + expiry traceability
model Inventory {
  id          String   @id @default(uuid())
  clientId    String
  productId   String
  binId       String
  batchNumber String
  expiryDate  DateTime @db.Date
  quantity    Int
  palletCount Int      @default(0)
  volumeM3    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  bin     Bin     @relation(fields: [binId], references: [id])

  @@unique([clientId, productId, binId, batchNumber, expiryDate])
  @@index([clientId])
  @@map("inventory")
}

/// Movement log — transfers + inbound/outbound quantities for billing
model StockMovement {
  id           String       @id @default(uuid())
  clientId     String
  productId    String
  fromBinId    String?
  toBinId      String?
  batchNumber  String
  expiryDate   DateTime     @db.Date
  quantity     Int
  beforeQty    Int
  afterQty     Int
  movedBy      String
  movementType MovementType
  createdAt    DateTime     @default(now())

  client  Client  @relation(fields: [clientId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  fromBin Bin?    @relation("FromBin", fields: [fromBinId], references: [id])
  toBin   Bin?    @relation("ToBin", fields: [toBinId], references: [id])
  user    User    @relation(fields: [movedBy], references: [id])

  @@index([clientId])
  @@map("stock_movements")
}

/// Audit trail — who, when, before/after quantities for all inventory actions
model AuditLog {
  id          String   @id @default(uuid())
  clientId    String?
  entityType  String
  entityId    String
  action      String
  performedBy String
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

/// Per-tenant rates: daily storage + inbound/outbound handling fees
model BillingRate {
  id           String   @id @default(uuid())
  clientId     String   @unique
  storageRate  Float
  inboundRate  Float
  outboundRate Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@map("billing_rates")
}

/// Monthly invoice header
model Invoice {
  id            String   @id @default(uuid())
  clientId      String
  invoiceMonth  String
  storageTotal  Float
  inboundTotal  Float
  outboundTotal Float
  grandTotal    Float
  createdAt     DateTime @default(now())

  client    Client            @relation(fields: [clientId], references: [id])
  lineItems InvoiceLineItem[]

  @@unique([clientId, invoiceMonth])
  @@index([clientId])
  @@map("invoices")
}

/// Invoice line items — storage, inbound handling, outbound handling
model InvoiceLineItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float
  rate        Float
  amount      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}
